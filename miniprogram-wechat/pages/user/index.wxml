<!-- 我的页面 -->
<view class="page-user">
  <!-- 用户信息 -->
  <view class="user-header">
    <view class="user-info" wx:if="{{isLogin}}">
      <!-- 头像：点击选择新头像 -->
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="user-avatar-img" mode="aspectFill" />
        <view wx:else class="user-avatar">
          <text>{{userInitial}}</text>
        </view>
      </button>
      <view class="user-detail">
        <view class="nickname-row">
          <input
            type="nickname"
            class="nickname-input"
            value="{{nickname}}"
            placeholder="点击设置昵称"
            bindblur="onNicknameBlur"
            bindinput="onNicknameInput"
          />
        </view>
        <view class="user-id">ID: {{userInfo.id}}</view>
      </view>
    </view>
    <view class="not-login" wx:else bindtap="onLogin">
      <view class="user-avatar">?</view>
      <view class="login-text">点击登录</view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <navigator url="/pages/order/index" class="menu-item" open-type="switchTab">
      <text class="menu-icon">📦</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">›</text>
    </navigator>

    <view class="menu-item" bindtap="onContact">
      <text class="menu-icon">📞</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <view class="btn btn-secondary" bindtap="onLogout">退出登录</view>
  </view>
</view>
