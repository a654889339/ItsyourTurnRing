<!-- 首页 -->
<view class="page-index">
  <!-- 顶部用户栏 -->
  <view class="top-bar">
    <view class="top-bar-left">
      <text class="shop-name">RingShop</text>
    </view>
    <navigator url="/pages/user/index" open-type="switchTab" class="top-bar-avatar">
      <image wx:if="{{userAvatar}}" src="{{userAvatar}}" class="avatar-img" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">
        <text>{{userInitial}}</text>
      </view>
    </navigator>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots autoplay circular wx:if="{{banners.length > 0}}">
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap" data-banner="{{item}}">
      <image src="{{item.image}}" mode="aspectFill" class="banner-image" />
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <scroll-view scroll-x class="category-nav">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-item {{currentCategory === item.code ? 'active' : ''}}"
      bindtap="onCategoryTap"
      data-code="{{item.code}}"
    >
      <view class="category-icon">
        <text wx:if="{{item.code === 'bracelet'}}">📿</text>
        <text wx:elif="{{item.code === 'necklace'}}">📿</text>
        <text wx:elif="{{item.code === 'ring'}}">💍</text>
        <text wx:elif="{{item.code === 'earring'}}">👂</text>
        <text wx:else>✨</text>
      </view>
      <view class="category-name">{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- 精选推荐 -->
  <view class="section" wx:if="{{featuredProducts.length > 0}}">
    <view class="section-title">精选推荐</view>
    <scroll-view scroll-x class="product-scroll">
      <view
        wx:for="{{featuredProducts}}"
        wx:key="id"
        class="product-scroll-item"
        bindtap="onProductTap"
        data-id="{{item.id}}"
      >
        <image src="{{item.main_image}}" mode="aspectFill" class="scroll-item-image" />
        <view class="scroll-item-name">{{item.name}}</view>
        <view class="scroll-item-price">¥{{item.price}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- 新品上市 -->
  <view class="section" wx:if="{{newProducts.length > 0}}">
    <view class="section-title">新品上市</view>
    <scroll-view scroll-x class="product-scroll">
      <view
        wx:for="{{newProducts}}"
        wx:key="id"
        class="product-scroll-item"
        bindtap="onProductTap"
        data-id="{{item.id}}"
      >
        <view class="badge new">新品</view>
        <image src="{{item.main_image}}" mode="aspectFill" class="scroll-item-image" />
        <view class="scroll-item-name">{{item.name}}</view>
        <view class="scroll-item-price">¥{{item.price}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- 商品列表 -->
  <view class="section">
    <view class="section-title">全部商品</view>
    <view class="product-grid">
      <view
        wx:for="{{products}}"
        wx:key="id"
        class="product-card"
        bindtap="onProductTap"
        data-id="{{item.id}}"
      >
        <image src="{{item.main_image}}" mode="aspectFill" class="product-image" />
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-material" wx:if="{{item.material}}">{{item.material}}</view>
          <view class="product-price">
            <text class="price">¥{{item.price}}</text>
            <text class="price-original" wx:if="{{item.original_price}}">¥{{item.original_price}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">加载中...</view>
  <view class="load-more" wx:elif="{{!hasMore && products.length > 0}}">没有更多了</view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && products.length === 0}}">
    <view class="empty-icon">💍</view>
    <view class="empty-text">暂无商品</view>
  </view>
</view>
