/* 首页样式 */
.page-index {
  padding-bottom: 20rpx;
}

/* 顶部用户栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #d4a574 0%, #8b7355 100%);
}

.top-bar-left {
  display: flex;
  align-items: center;
}

.shop-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.top-bar-avatar {
  display: flex;
  align-items: center;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.6);
}

.avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 轮播图 */
.banner-swiper {
  height: 300rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 分类导航 */
.category-nav {
  white-space: nowrap;
  background: #fff;
  padding: 20rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  margin-right: 20rpx;
}

.category-item.active .category-name {
  color: #d4a574;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

/* 区块 */
.section {
  padding: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 横向滚动商品 */
.product-scroll {
  white-space: nowrap;
}

.product-scroll-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.scroll-item-image {
  width: 240rpx;
  height: 240rpx;
}

.scroll-item-name {
  padding: 16rpx;
  font-size: 26rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.scroll-item-price {
  padding: 0 16rpx 16rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  border-radius: 6rpx;
}

.badge.new {
  background: #52c41a;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 340rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-material {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
}
