.page-checkout {
  padding: 20rpx 20rpx 140rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.address-list {
  margin-bottom: 16rpx;
}

.address-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.address-item.selected {
  border-color: #d4a574;
  background: #fdf8f4;
}

.addr-check {
  padding-top: 8rpx;
  margin-right: 16rpx;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
}

.radio.checked {
  border-color: #d4a574;
  background: #d4a574;
}

.addr-info {
  flex: 1;
}

.addr-contact {
  margin-bottom: 8rpx;
}

.addr-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.addr-phone {
  font-size: 26rpx;
  color: #666;
}

.addr-detail {
  font-size: 24rpx;
  color: #999;
}

.empty-address {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 地址表单弹层 */
.address-form-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.address-form {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  box-sizing: border-box;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  height: 60rpx;
}

.form-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
  gap: 20rpx;
}

.form-actions .btn {
  flex: 1;
  text-align: center;
}

/* 商品列表 */
.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 28rpx;
  color: #d4a574;
  font-weight: bold;
}

.goods-qty {
  font-size: 24rpx;
  color: #999;
}

/* 备注 */
.remark-input {
  width: 100%;
  height: 140rpx;
  font-size: 26rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: none;
}

/* 底部栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 50;
}

.footer-total {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  color: #d4a574;
  font-size: 36rpx;
  font-weight: bold;
}

.submit-btn {
  padding: 16rpx 48rpx;
  font-size: 30rpx;
}

.submit-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 通用按钮 */
.btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.btn-primary {
  background: #d4a574;
  color: #fff;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}

.btn-small {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}
